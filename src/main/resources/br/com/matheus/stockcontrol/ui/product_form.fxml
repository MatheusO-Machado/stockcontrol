<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.matheus.stockcontrol.ui.controller.ProductFormController"
      spacing="10">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label fx:id="lblTitle" text="Novo Produto" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="90" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="txtName" promptText="Ex: Teclado Mecânico"
                   GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="SKU:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="txtSku" promptText="Ex: SKU-100"
                   GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Quantidade:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <Spinner fx:id="spQuantity" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="Preço:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="txtPrice" promptText="Ex: 199.90"
                   GridPane.rowIndex="3" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#onCancel"/>
        <Button text="Salvar" defaultButton="true" onAction="#onSave"/>
    </HBox>
</VBox>